{
    "name": "Example 2",
    "slug": "example2",
    "info": "Example e-package for testing dynamic router",
    "special_pages": {},
    "spaces": [
        {
            "namespace": "example2",
            "executor_type": "luaz",
            "executor_sub_type": "",
            "server_file": "server.lua",
            "route_options": {
                "router_type": "dynamic",
                "serve_folder": "public",
                "force_html_extension": true,
                "force_index_html_file": true,
                "on_not_found_file": "",
                "trim_path_prefix": "",
                "template_folder": "templates",
                "routes": [
                    {
                        "path": "/",
                        "method": "GET",
                        "type": "static",
                        "handler": "",
                        "file": "index.html"
                    },
                    {
                        "path": "/about",
                        "method": "GET",
                        "type": "static",
                        "handler": "",
                        "file": "about.html"
                    },
                    {
                        "path": "/product/:id/edit",
                        "method": "GET",
                        "type": "static",
                        "handler": "",
                        "file": "edit.html"
                    },
                    {
                        "path": "/categories/:id/page.html",
                        "method": "GET",
                        "type": "template",
                        "handler": "get_category_page",
                        "file": "category.template.html"
                    },
                    {
                        "path": "/user/:userId/profile",
                        "method": "GET",
                        "type": "template",
                        "handler": "get_user_profile",
                        "file": "profile.template.html"
                    },
                    {
                        "path": "/api/categories/create",
                        "method": "POST",
                        "type": "api",
                        "handler": "create_category",
                        "file": ""
                    },
                    {
                        "path": "/api/categories/:id",
                        "method": "GET",
                        "type": "api",
                        "handler": "get_category",
                        "file": ""
                    },
                    {
                        "path": "/api/categories/:id",
                        "method": "DELETE",
                        "type": "api",
                        "handler": "delete_category",
                        "file": ""
                    }
                ]
            },
            "dev_serve_port": 0,
            "is_default": true
        }
    ],
    "capabilities": [],
    "canonical_url": "",
    "format_version": "0.0.2",
    "author_name": "Bornjre",
    "author_email": "bornjre@gmail.com",
    "author_site": "https://github.com/bornjre",
    "source_code": "",
    "license": "MIT",
    "version": "0.0.1",
    "tags": [
        "dynamic-router",
        "example"
    ]
}